# Copy to .env.local and fill in. NEVER commit real secrets.

# --- Database -------------------------------------------------------------
# Dev Aurora endpoint (or a local Postgres). Aurora requires TLS.
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/abode
# Set to 'disable' ONLY for a plain local Postgres without TLS.
# PGSSL=disable

# --- App ------------------------------------------------------------------
AWS_REGION=us-east-1
APP_URL=http://localhost:3000

# --- Cognito (fill after infra/06_cognito.sh) -----------------------------
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=
COGNITO_CLIENT_SECRET=
COGNITO_DOMAIN=

# --- S3 media (fill after infra/05_s3.sh) ---------------------------------
S3_MEDIA_BUCKET=

# --- Stripe (test mode) ---------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# --- Mapbox (handyman map) ------------------------------------------------
NEXT_PUBLIC_MAPBOX_TOKEN=
